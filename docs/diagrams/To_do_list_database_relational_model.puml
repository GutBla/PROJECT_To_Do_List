@startuml Modelo Relacional Proyecto To-Do-List

hide circle
skinparam linetype ortho

entity Usuario {
  * id : INT
  --
  * email : VARCHAR(255)
  * password_hash : VARCHAR(255)
  * nombre_completo : VARCHAR(255)
  fecha_creacion : TIMESTAMP
  fecha_actualizacion : TIMESTAMP
}

entity CategoriaPredeterminada {
  * id : INT
  --
  * nombre : VARCHAR(255)
  descripcion : TEXT
}

entity Categoria {
  * id : INT
  --
  * usuario_id : INT
  categoria_predeterminada_id : INT
  es_predeterminada : BOOLEAN
  fecha_creacion : TIMESTAMP
  fecha_actualizacion : TIMESTAMP
}

entity Tarea {
  * id : INT
  --
  categoria_id : INT
  * usuario_id : INT
  * titulo : VARCHAR(255)
  descripcion : TEXT
  estado : ENUM('NUEVA', 'EN_PROGRESO', 'COMPLETADA', 'PENDIENTE')
  fecha_vencimiento : DATE
  fecha_creacion : TIMESTAMP
  fecha_actualizacion : TIMESTAMP
  fecha_completado : TIMESTAMP
}

entity UsuarioTarea {
  * usuario_id : INT
  * tarea_id : INT
  --
  fecha_asignacion : TIMESTAMP
  permisos : ENUM('LECTURA', 'ESCRITURA', 'PROPIETARIO')
}

entity LogTareaEliminada {
  * id : INT
  --
  tarea_id : INT
  usuario_id : INT
  titulo : VARCHAR(255)
  descripcion : TEXT
  estado : ENUM('NUEVA', 'EN_PROGRESO', 'COMPLETADA', 'PENDIENTE')
  fecha_vencimiento : DATE
  fecha_completado : TIMESTAMP
  fecha_eliminacion : TIMESTAMP
}

Usuario ||--o{ Categoria : "1:N"
CategoriaPredeterminada ||--o{ Categoria : "1:N (predeterminadas)"
Categoria ||--o{ Tarea : "1:N (opcional)"
Usuario ||--o{ Tarea : "1:N (propietario)"
UsuarioTarea }|..|| Usuario : "M:N (usuarios asignados)"
UsuarioTarea }|..|| Tarea : "M:N (tareas asignadas)"
Tarea ||--o{ LogTareaEliminada : "1:N (registro de eliminación)"
Usuario ||--o{ LogTareaEliminada : "1:N (usuario que eliminó)"

note top of Categoria
  FK usuario_id -> Usuario.id (ON DELETE CASCADE)
  FK categoria_predeterminada_id -> CategoriaPredeterminada.id (ON DELETE SET NULL)
end note

note top of Tarea
  FK categoria_id -> Categoria.id (ON DELETE SET NULL)
  FK usuario_id -> Usuario.id (ON DELETE CASCADE)
end note

note top of UsuarioTarea
  PK (usuario_id, tarea_id)
  FK usuario_id -> Usuario.id (ON DELETE CASCADE)
  FK tarea_id -> Tarea.id (ON DELETE CASCADE)
end note

note top of LogTareaEliminada
  FK tarea_id -> Tarea.id (lógico, no físico)
  FK usuario_id -> Usuario.id (lógico, no físico)
end note

@enduml
